<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {%- if settings.favicon -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --b: {{ settings.color_brand }};
      --bl: {{ settings.color_brand_light }};
      --bm: {{ settings.color_brand_mid }};
      --bd: {{ settings.color_brand_dark }};
      --w: {{ settings.color_bg }};
      --off: {{ settings.color_off }};
      --ink: {{ settings.color_ink }};
      --mu: {{ settings.color_muted }};
      --br: {{ settings.color_border }};
    }
  </style>
</head>
<body>
  <div class="password-page">
    <p class="nav-logo" style="margin-bottom:24px">
      <span class="name" style="font-size:18px">{{ shop.name }}</span>
    </p>
    <h1>Coming Soon</h1>
    {%- if shop.password_message != blank -%}
      <p>{{ shop.password_message }}</p>
    {%- else -%}
      <p>We're working on something beautiful. Enter the password to preview.</p>
    {%- endif -%}
    {{ content_for_layout }}
  </div>
</body>
</html>
