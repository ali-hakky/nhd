<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }}{% unless page_title contains shop.name %} — {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <script>
    window.Shopify = window.Shopify || {};
    window.Shopify.formatMoney = function(cents) {
      return '{{ cart.currency.symbol }}' + (cents / 100).toFixed(2);
    };
  </script>
</head>
<body>
  {%- sections 'header-group' -%}
  <main id="main">{{ content_for_layout }}</main>
  {%- sections 'footer-group' -%}
  {%- section 'cart-drawer' -%}
  <div class="mobile-nav" id="mobile-nav">
    <div class="mobile-nav-head">
      <span class="nav-logo">
        <span class="name">{{ shop.name }}</span>
      </span>
      <button class="mobile-nav-close" aria-label="Close menu">&times;</button>
    </div>
    {%- if linklists.main-menu.links.size > 0 -%}
      {%- for link in linklists.main-menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
        {%- for child in link.links -%}
          <a href="{{ child.url }}" style="padding-left:20px;font-size:10px">{{ child.title }}</a>
        {%- endfor -%}
      {%- endfor -%}
    {%- else -%}
      <a href="{{ routes.collections_url }}/seating">Seating</a>
      <a href="{{ routes.collections_url }}/tables">Tables</a>
      <a href="{{ routes.collections_url }}/consoles">Consoles</a>
      <a href="{{ routes.collections_url }}/stools">Stools</a>
      <a href="{{ routes.collections_url }}/beds">Beds</a>
      <a href="{{ routes.collections_url }}/accessories">Accessories</a>
      <a href="{{ routes.collections_url }}/new-in">New In</a>
    {%- endif -%}
  </div>
  <script src="{{ 'global.js' | asset_url }}" defer></script>
</body>
</html>
