{%- liquid
  assign profile_url = 'https://www.instagram.com/' | append: section.settings.handle | remove: '@'
-%}

<section class="insta">
  {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
  <a href="{{ profile_url }}" target="_blank" rel="noopener" class="insta-title-link">
    <h2 class="insta-title">{{ section.settings.heading }}</h2>
  </a>
  {%- if section.settings.handle != blank -%}
    <a href="{{ profile_url }}" target="_blank" rel="noopener" class="insta-handle">{{ section.settings.handle }}</a>
  {%- endif -%}
  <div class="insta-grid">
    {%- for block in section.blocks -%}
      {%- if block.settings.post_url != blank -%}
        <a href="{{ block.settings.post_url }}" target="_blank" rel="noopener" class="insta-cell" {{ block.shopify_attributes }}>
      {%- else -%}
        <div class="insta-cell" {{ block.shopify_attributes }}>
      {%- endif -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.caption | default: 'Instagram post' }}
          {%- else -%}
            <div class="ph" style="width:100%;height:100%;aspect-ratio:1">Insta {{ forloop.index }}</div>
          {%- endif -%}
      {%- if block.settings.post_url != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Instagram",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Follow along" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The World of NHD" },
    { "type": "text", "id": "handle", "label": "Handle", "default": "@nazlyhabibdesigns" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "post_url", "label": "Instagram post URL" },
        { "type": "text", "id": "caption", "label": "Alt text / caption" }
      ]
    }
  ],
  "presets": [{ "name": "Instagram", "blocks": [
    { "type": "image" },
    { "type": "image" },
    { "type": "image" },
    { "type": "image" },
    { "type": "image" },
    { "type": "image" }
  ] }]
}
{% endschema %}
