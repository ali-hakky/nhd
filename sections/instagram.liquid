{%- comment -%} Instagram strip {%- endcomment -%}
<section class="insta">
  {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
  <h2 class="insta-title">{{ section.settings.heading }}</h2>
  {%- if section.settings.handle != blank -%}
    <a href="{{ section.settings.handle_url | default: '#' }}" class="insta-handle" target="_blank" rel="noopener">{{ section.settings.handle }}</a>
  {%- endif -%}
  <div class="insta-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: section.settings.handle_url | default: '#' }}" class="insta-cell" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 400 | image_tag: alt: 'Instagram post', loading: 'lazy', widths: '200,300,400' }}
        {%- elsif block.settings.image_asset != blank -%}
          <img src="{{ block.settings.image_asset | asset_url }}" alt="Instagram post" loading="lazy">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Instagram strip",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Follow along" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The World of NHD" },
    { "type": "text", "id": "handle", "label": "Handle", "default": "@nazlyhabibdesigns" },
    { "type": "url", "id": "handle_url", "label": "Instagram URL", "default": "https://instagram.com/nazlyhabibdesigns" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_asset", "label": "Image asset filename", "info": "e.g. insta-1.png" },
        { "type": "url", "id": "link", "label": "Post link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Instagram strip",
      "blocks": [
        { "type": "post", "settings": { "image_asset": "insta-1.png" } },
        { "type": "post", "settings": { "image_asset": "insta-2.png" } },
        { "type": "post", "settings": { "image_asset": "insta-3.png" } },
        { "type": "post", "settings": { "image_asset": "insta-4.png" } },
        { "type": "post", "settings": { "image_asset": "insta-5.png" } },
        { "type": "post", "settings": { "image_asset": "insta-6.png" } }
      ]
    }
  ]
}
{% endschema %}
