<section class="spotlight">
  <div class="spot-img">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.title }}
    {%- else -%}
      <div class="ph" style="width:100%;height:100%">Product Spotlight Photo</div>
    {%- endif -%}
  </div>
  <div>
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 class="spot-title">{{ section.settings.title }}{% if section.settings.title_accent != blank %}<br><em>{{ section.settings.title_accent }}</em>{% endif %}</h2>
    {%- if section.settings.body != blank -%}<p class="spot-body">{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="specs">
        {%- for block in section.blocks -%}
          <div class="spec" {{ block.shopify_attributes }}>
            <div class="spec-label">{{ block.settings.label }}</div>
            <div class="spec-val">{{ block.settings.value }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_url | default: '/pages/contact' }}" class="btn">{{ section.settings.btn_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product spotlight",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Product spotlight" },
    { "type": "text", "id": "title", "label": "Title", "default": "The Upholstered" },
    { "type": "text", "id": "title_accent", "label": "Title italic", "default": "Console" },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Nazly's latest obsession and one of the most saved pieces on her feed. Unique, unexpected — yet beautifully functional and timeless." },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Enquire Now" },
    { "type": "url", "id": "btn_url", "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Material" },
        { "type": "text", "id": "value", "label": "Value", "default": "Rattan & Wicker" }
      ]
    }
  ],
  "presets": [{ "name": "Product spotlight", "blocks": [
    { "type": "spec", "settings": { "label": "Customisation", "value": "Fully Bespoke" } },
    { "type": "spec", "settings": { "label": "Lead Time", "value": "3–4 Weeks" } },
    { "type": "spec", "settings": { "label": "Fabric", "value": "Your Choice" } },
    { "type": "spec", "settings": { "label": "Order Type", "value": "Pre-order Only" } }
  ] }]
}
{% endschema %}
