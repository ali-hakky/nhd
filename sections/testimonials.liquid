<section class="testi">
  <div style="text-align:center">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:300;color:var(--ink);margin-top:10px">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <em style="font-style:italic;color:var(--bd)">{{ section.settings.heading_accent }}</em>{% endif %}</h2>
  </div>
  <div class="testi-grid">
    {%- for block in section.blocks -%}
      <div class="testi-card" {{ block.shopify_attributes }}>
        <div class="testi-stars">★★★★★</div>
        <p class="testi-q">"{{ block.settings.quote }}"</p>
        <p class="testi-who">— {{ block.settings.author }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Client love" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our clients" },
    { "type": "text", "id": "heading_accent", "label": "Heading italic", "default": "say" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Beautiful craftsmanship and fabric." },
        { "type": "text", "id": "author", "label": "Author", "default": "Client Name" }
      ]
    }
  ],
  "presets": [{ "name": "Testimonials", "blocks": [
    { "type": "testimonial", "settings": { "quote": "The Hamptons Armchair is the most complimented piece in our home. It feels like it was always meant to be there.", "author": "Sophie T., London" } },
    { "type": "testimonial", "settings": { "quote": "Beautiful craftsmanship and fabric — absolutely gorgeous. Nazly understood exactly what I wanted.", "author": "coffeeandthings, Instagram" } },
    { "type": "testimonial", "settings": { "quote": "The X Stools in GP & J Baker are a genuine conversation piece. Worth every penny and every week of the wait.", "author": "Layla H., Cairo" } }
  ] }]
}
{% endschema %}
