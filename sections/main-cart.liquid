<div class="cart-page">
  <h1>Your Cart</h1>

  {%- if cart.item_count > 0 -%}
    <form action="/cart" method="post">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr>
              <td>
                <div class="cart-prod">
                  <a href="{{ item.url }}">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" loading="lazy">
                    {%- endif -%}
                  </a>
                  <div>
                    <div class="cart-prod-name">{{ item.product.title }}</div>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <div class="cart-prod-variant">{{ item.variant.title }}</div>
                    {%- endunless -%}
                  </div>
                </div>
              </td>
              <td>{{ item.price | money }}</td>
              <td>
                <div class="cart-qty">
                  <button type="button" data-qty-change="-1" data-key="{{ item.key }}">-</button>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-key="{{ item.key }}">
                  <button type="button" data-qty-change="1" data-key="{{ item.key }}">+</button>
                </div>
              </td>
              <td>{{ item.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div class="cart-totals">
        <div class="cart-totals-row">
          <span>Subtotal</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <p style="font-size:10px;color:var(--mu);margin-bottom:12px">Shipping and taxes calculated at checkout.</p>
        <div class="cart-totals-row total">
          <span>Total</span>
          <span>{{ cart.total_price | money }}</span>
        </div>
        <button type="submit" name="checkout" class="btn" style="width:100%;text-align:center;margin-top:16px">Checkout</button>
      </div>
    </form>
  {%- else -%}
    <div style="text-align:center;padding:60px 20px">
      <p style="color:var(--mu);margin-bottom:20px">Your cart is empty.</p>
      <a href="/collections" class="btn">Continue Shopping</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart page",
  "tag": "section",
  "settings": []
}
{% endschema %}
