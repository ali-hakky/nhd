<div class="cart-page">
  <h1>{{ 'general.cart.title' | t }}</h1>
  {%- if cart.item_count > 0 -%}
    <form action="/cart" method="post">
      <table class="cart-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr>
              <td>
                <div class="cart-prod">
                  <a href="{{ item.url }}">
                    {%- if item.image -%}
                      {{ item.image | image_url: width: 160 | image_tag: alt: item.title }}
                    {%- endif -%}
                  </a>
                  <div>
                    <div class="cart-prod-name"><a href="{{ item.url }}" style="text-decoration:none;color:inherit">{{ item.product.title }}</a></div>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <div class="cart-prod-variant">{{ item.variant.title }}</div>
                    {%- endunless -%}
                    <button type="button" class="cart-item-remove" data-remove-key="{{ item.key }}">{{ 'general.cart.remove' | t }}</button>
                  </div>
                </div>
              </td>
              <td>{{ item.price | money }}</td>
              <td>
                <div class="cart-qty">
                  <button type="button" data-qty-change="-1" data-key="{{ item.key }}">−</button>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" data-key="{{ item.key }}">
                  <button type="button" data-qty-change="1" data-key="{{ item.key }}">+</button>
                </div>
              </td>
              <td>{{ item.line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>

      <div class="cart-totals">
        <div class="cart-totals-row"><span>{{ 'general.cart.subtotal' | t }}</span><span>{{ cart.total_price | money }}</span></div>
        <div class="cart-totals-row" style="font-size:11px;color:var(--mu)"><span>{{ 'general.cart.shipping_note' | t }}</span></div>
        <div class="cart-totals-row total"><span>Total</span><span>{{ cart.total_price | money }}</span></div>
        <button type="submit" name="checkout" class="btn" style="width:100%;text-align:center;margin-top:16px">{{ 'general.cart.checkout' | t }}</button>
      </div>
    </form>
  {%- else -%}
    <div style="text-align:center;padding:60px 20px">
      <p style="color:var(--mu);margin-bottom:20px">{{ 'general.cart.empty' | t }}</p>
      <a href="/collections" class="btn">{{ 'general.cart.continue' | t }}</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Cart" },
    { "type": "checkbox", "id": "show_note", "label": "Show cart note field", "default": false },
    { "type": "text", "id": "empty_text", "label": "Empty cart text", "default": "Your cart is currently empty." },
    { "type": "text", "id": "continue_label", "label": "Continue shopping button label", "default": "Continue Shopping" },
    { "type": "url", "id": "continue_url", "label": "Continue shopping URL" }
  ]
}
{% endschema %}
