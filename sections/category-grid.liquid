<section class="section" style="padding-bottom:0">
  <div class="sec-head">
    <div>
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="sec-title">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent }}</em>{% endif %}</h2>
    </div>
  </div>
  <div class="cat-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.url | default: '#' }}" class="cat-card" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title }}
        {%- else -%}
          <div class="ph">{{ block.settings.title }} Photo</div>
        {%- endif -%}
        <div class="cat-overlay">
          <div class="cat-name">{{ block.settings.title }}</div>
          {%- if block.settings.subtitle != blank -%}<div class="cat-sub">{{ block.settings.subtitle }}</div>{%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the" },
    { "type": "text", "id": "heading_accent", "label": "Heading italic", "default": "Collection" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Category" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Subcategories" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Category grid", "blocks": [
    { "type": "category", "settings": { "title": "Seating", "subtitle": "Armchairs · Sofas" } },
    { "type": "category", "settings": { "title": "Tables", "subtitle": "Coffee · Side · Painted" } },
    { "type": "category", "settings": { "title": "Consoles", "subtitle": "Hall · Buffet · Bespoke" } },
    { "type": "category", "settings": { "title": "Stools & Stands", "subtitle": "X Stools · Butler Stands" } },
    { "type": "category", "settings": { "title": "Accessories", "subtitle": "Trays · Mirrors · Lighting" } }
  ] }]
}
{% endschema %}
