{%- comment -%} Shop by category — image grid linking to collections {%- endcomment -%}
<section class="section" style="padding-bottom:0">
  <div class="sec-head">
    <div>
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h2 class="sec-title">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent }}</em>{% endif %}</h2>
    </div>
  </div>
  <div class="cat-grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign coll = block.settings.collection
        assign url = block.settings.link
        if url == blank and coll != blank
          assign url = coll.url
        endif
        assign img = block.settings.image
        if img == blank and coll.featured_image
          assign img = coll.featured_image
        endif
        assign name = block.settings.name
        if name == blank and coll != blank
          assign name = coll.title
        endif
      -%}
      <a href="{{ url | default: '#' }}" class="cat-card" {{ block.shopify_attributes }}>
        {%- if img != blank -%}
          {{ img | image_url: width: 600 | image_tag: alt: name, loading: 'lazy', widths: '300,450,600' }}
        {%- elsif block.settings.image_asset != blank -%}
          <img src="{{ block.settings.image_asset | asset_url }}" alt="{{ name | escape }}" loading="lazy">
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="cat-overlay">
          <div class="cat-name">{{ name }}</div>
          {%- if block.settings.sub != blank -%}<div class="cat-sub">{{ block.settings.sub }}</div>{%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the" },
    { "type": "text", "id": "heading_accent", "label": "Heading (italic accent)", "default": "Collection" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "image_asset", "label": "Image asset filename", "info": "Theme asset used if no image picked, e.g. cat-seating.jpg" },
        { "type": "text", "id": "name", "label": "Name override" },
        { "type": "text", "id": "sub", "label": "Subtitle", "default": "Armchairs · Sofas" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        { "type": "category", "settings": { "name": "Seating", "sub": "Armchairs · Sofas", "image_asset": "cat-seating.jpg" } },
        { "type": "category", "settings": { "name": "Tables", "sub": "Coffee · Side · Painted", "image_asset": "cat-tables.jpg" } },
        { "type": "category", "settings": { "name": "Consoles", "sub": "Hall · Buffet · Bespoke", "image_asset": "cat-consoles.jpg" } },
        { "type": "category", "settings": { "name": "Stools & Stands", "sub": "X Stools · Butler Stands", "image_asset": "cat-stools.jpg" } },
        { "type": "category", "settings": { "name": "Accessories", "sub": "Trays · Mirrors · Lighting", "image_asset": "cat-accessories.jpg" } }
      ]
    }
  ]
}
{% endschema %}
