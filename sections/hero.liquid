<section class="hero">
  <div class="hero-bg">
    <div class="hero-pane">
      {%- if section.settings.image_1 != blank -%}
        {{ section.settings.image_1 | image_url: width: 1200 | image_tag: loading: 'eager', alt: section.settings.heading }}
      {%- else -%}
        <div class="ph" style="width:100%;height:100%">Hero Image 1</div>
      {%- endif -%}
    </div>
    <div class="hero-pane">
      {%- if section.settings.image_2 != blank -%}
        {{ section.settings.image_2 | image_url: width: 900 | image_tag: loading: 'eager', alt: section.settings.heading }}
      {%- else -%}
        <div class="ph" style="width:100%;height:100%">Hero Image 2</div>
      {%- endif -%}
    </div>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h1>{{ section.settings.heading }}{% if section.settings.heading_accent != blank %}<br><em>{{ section.settings.heading_accent }}</em>{% endif %}</h1>
    {%- if section.settings.subheading != blank -%}<p class="hero-sub">{{ section.settings.subheading }}</p>{%- endif -%}
    <div class="hero-btns">
      {%- if section.settings.btn_label != blank -%}<a href="{{ section.settings.btn_url | default: routes.all_products_collection_url }}" class="btn">{{ section.settings.btn_label }}</a>{%- endif -%}
      {%- if section.settings.ghost_label != blank -%}<a href="{{ section.settings.ghost_url | default: '/pages/contact' }}" class="btn-ghost">{{ section.settings.ghost_label }}</a>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Left image (large)" },
    { "type": "image_picker", "id": "image_2", "label": "Right image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Cairo · London · Handcrafted · Made to Order" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Furniture with" },
    { "type": "text", "id": "heading_accent", "label": "Heading italic", "default": "personality." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Rattan, wicker & bespoke upholstery" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Shop the Collection" },
    { "type": "url", "id": "btn_url", "label": "Button URL" },
    { "type": "text", "id": "ghost_label", "label": "Ghost button label", "default": "Enquire Bespoke" },
    { "type": "url", "id": "ghost_url", "label": "Ghost button URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
