{%- comment -%} Sticky header with logo, utility links, icons and mega-menu nav {%- endcomment -%}
{%- liquid
  assign menu = section.settings.menu
  assign nav = linklists[menu]
-%}

<nav class="nav">
  <div class="nav-top">
    <button class="nav-toggle" data-mobile-nav-open aria-label="Open menu">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <div class="nav-links-left">
      {%- if section.settings.left_link_1_label != blank -%}<a href="{{ section.settings.left_link_1_url }}">{{ section.settings.left_link_1_label }}</a>{%- endif -%}
      {%- if section.settings.left_link_2_label != blank -%}<a href="{{ section.settings.left_link_2_url }}">{{ section.settings.left_link_2_label }}</a>{%- endif -%}
    </div>

    <a href="{{ routes.root_url }}" class="nav-logo">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 320 | image_tag: class: 'logo-img', alt: shop.name, widths: '160,320' }}
      {%- else -%}
        <span class="name">{{ section.settings.logo_text | default: shop.name }}</span>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}<span class="sub">{{ section.settings.tagline }}</span>{%- endif -%}
    </a>

    <div class="nav-links-right">
      {%- if section.settings.right_link_label != blank -%}<a href="{{ section.settings.right_link_url }}">{{ section.settings.right_link_label }}</a>{%- endif -%}
      <div class="nav-icons">
        <a href="{{ routes.search_url }}" aria-label="Search">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>
        <a href="{{ routes.account_url }}" aria-label="Account" class="cart-link">
          <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <button data-cart-open aria-label="Cart" class="cart-link">
          <span class="cart-count-bubble">
            <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span data-cart-count {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
          </span>
        </button>
      </div>
    </div>
  </div>

  {%- if nav and nav.links.size > 0 -%}
    <div class="nav-bar">
      {%- for link in nav.links -%}
        <div class="nav-item{% if link.links.size == 0 and forloop.last and section.settings.highlight_last %} is-accent{% endif %}">
          <a href="{{ link.url }}">{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <div class="dropdown">
              {%- for child in link.links -%}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    {%- comment -%} Fallback nav matching the brand design, shown until a Shopify menu is created {%- endcomment -%}
    {%- assign nav_blocks = section.blocks | where: 'type', 'nav_item' -%}
    <div class="nav-bar">
      {%- if nav_blocks.size > 0 -%}
        {%- for block in nav_blocks -%}
          <div class="nav-item{% if block.settings.accent %} is-accent{% endif %}" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url | default: '#' }}">{{ block.settings.label }}</a>
            {%- if block.settings.dropdown_links != blank -%}
              <div class="dropdown">
                {%- assign dd_items = block.settings.dropdown_links | split: '|' -%}
                {%- for dd in dd_items -%}
                  <a href="#">{{ dd | strip }}</a>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="nav-item"><a href="/collections/seating">Seating</a><div class="dropdown"><a href="#">Hamptons Armchair</a><a href="#">Riviera Rattan</a><a href="#">Amalfi Grande Sofa</a><a href="#">Miniature Chair</a><a href="#">View All Seating</a></div></div>
        <div class="nav-item"><a href="/collections/tables">Tables</a><div class="dropdown"><a href="#">Coffee Tables</a><a href="#">Moroccan Side Table</a><a href="#">Painted Side Tables</a><a href="#">The Sloan</a><a href="#">View All Tables</a></div></div>
        <div class="nav-item"><a href="/collections/consoles">Consoles</a><div class="dropdown"><a href="#">Hortensia Console</a><a href="#">Boltons Console</a><a href="#">Burl Wood Console</a><a href="#">Marrakech Console</a><a href="#">Upholstered Console</a><a href="#">View All Consoles</a></div></div>
        <div class="nav-item"><a href="/collections/stools">Stools</a><div class="dropdown"><a href="#">X Stools — All Fabrics</a><a href="#">Butler's Stands</a><a href="#">Bobbin Bar Stools</a><a href="#">View All Stools</a></div></div>
        <div class="nav-item"><a href="/collections/beds">Beds</a><div class="dropdown"><a href="#">Regency Headboard</a><a href="#">Bed Frames (Pre-order)</a></div></div>
        <div class="nav-item"><a href="/collections/accessories">Accessories</a><div class="dropdown"><a href="#">Swoon Trays</a><a href="#">Butler's Tray Stands</a><a href="#">Bahamas Lantern</a><a href="#">Arabesque Mirror</a><a href="#">Bar Cart</a><a href="#">View All</a></div></div>
        <div class="nav-item is-accent"><a href="/collections/new-in">New In</a></div>
      {%- endif -%}
    </div>
  {%- endif -%}
</nav>

{%- comment -%} Mobile slide-in nav {%- endcomment -%}
<div class="mobile-nav" id="MobileNav" data-mobile-nav>
  <div class="mobile-nav-panel">
    <button class="mobile-nav-close" data-mobile-nav-close aria-label="Close menu">&times;</button>
    <div style="clear:both"></div>
    {%- if nav -%}
      {%- for link in nav.links -%}
        <a href="{{ link.url }}" class="parent">{{ link.title }}</a>
        {%- for child in link.links -%}
          <a href="{{ child.url }}" class="child">{{ child.title }}</a>
        {%- endfor -%}
      {%- endfor -%}
    {%- else -%}
      {%- assign nav_blocks_m = section.blocks | where: 'type', 'nav_item' -%}
      {%- if nav_blocks_m.size > 0 -%}
        {%- for block in nav_blocks_m -%}
          <a href="{{ block.settings.url | default: '#' }}" class="parent">{{ block.settings.label }}</a>
          {%- if block.settings.dropdown_links != blank -%}
            {%- assign dd_items_m = block.settings.dropdown_links | split: '|' -%}
            {%- for dd in dd_items_m -%}
              <a href="#" class="child">{{ dd | strip }}</a>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a href="/collections/seating" class="parent">Seating</a>
        <a href="/collections/tables" class="parent">Tables</a>
        <a href="/collections/consoles" class="parent">Consoles</a>
        <a href="/collections/stools" class="parent">Stools</a>
        <a href="/collections/beds" class="parent">Beds</a>
        <a href="/collections/accessories" class="parent">Accessories</a>
        <a href="/collections/new-in" class="parent">New In</a>
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.left_link_1_label != blank -%}<a href="{{ section.settings.left_link_1_url }}" class="parent">{{ section.settings.left_link_1_label }}</a>{%- endif -%}
    {%- if section.settings.left_link_2_label != blank -%}<a href="{{ section.settings.left_link_2_url }}" class="parent">{{ section.settings.left_link_2_label }}</a>{%- endif -%}
    {%- if section.settings.right_link_label != blank -%}<a href="{{ section.settings.right_link_url }}" class="parent">{{ section.settings.right_link_label }}</a>{%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "Nazly Habib Design" },
    { "type": "text", "id": "tagline", "label": "Tagline under logo", "default": "Handcrafted Interiors · Cairo & London" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu", "info": "If this menu exists in Shopify, it overrides the nav blocks below." },
    { "type": "checkbox", "id": "highlight_last", "label": "Highlight last menu item", "default": true },
    { "type": "header", "content": "Top-left links" },
    { "type": "text", "id": "left_link_1_label", "label": "Link 1 label", "default": "About" },
    { "type": "url", "id": "left_link_1_url", "label": "Link 1 URL" },
    { "type": "text", "id": "left_link_2_label", "label": "Link 2 label", "default": "Bespoke Orders" },
    { "type": "url", "id": "left_link_2_url", "label": "Link 2 URL" },
    { "type": "header", "content": "Top-right link" },
    { "type": "text", "id": "right_link_label", "label": "Link label", "default": "Contact" },
    { "type": "url", "id": "right_link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "nav_item",
      "name": "Nav item",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Seating" },
        { "type": "url", "id": "url", "label": "Link" },
        { "type": "text", "id": "dropdown_links", "label": "Dropdown items (pipe-separated)", "info": "e.g. Hamptons Armchair | Riviera Rattan | View All" },
        { "type": "checkbox", "id": "accent", "label": "Highlight colour", "default": false }
      ]
    }
  ],
  "max_blocks": 10
}
{% endschema %}
