{%- comment -%} Sticky header with logo, utility links, icons and mega-menu nav {%- endcomment -%}
{%- liquid
  assign menu = section.settings.menu
  assign nav = linklists[menu]
-%}

<nav class="nav">
  <div class="nav-top">
    <button class="nav-toggle" data-mobile-nav-open aria-label="Open menu">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    <div class="nav-links-left">
      {%- if section.settings.left_link_1_label != blank -%}<a href="{{ section.settings.left_link_1_url }}">{{ section.settings.left_link_1_label }}</a>{%- endif -%}
      {%- if section.settings.left_link_2_label != blank -%}<a href="{{ section.settings.left_link_2_url }}">{{ section.settings.left_link_2_label }}</a>{%- endif -%}
    </div>

    <a href="{{ routes.root_url }}" class="nav-logo">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 320 | image_tag: class: 'logo-img', alt: shop.name, widths: '160,320' }}
      {%- else -%}
        <span class="name">{{ section.settings.logo_text | default: shop.name }}</span>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}<span class="sub">{{ section.settings.tagline }}</span>{%- endif -%}
    </a>

    <div class="nav-links-right">
      {%- if section.settings.right_link_label != blank -%}<a href="{{ section.settings.right_link_url }}">{{ section.settings.right_link_label }}</a>{%- endif -%}
      <div class="nav-icons">
        <a href="{{ routes.search_url }}" aria-label="Search">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>
        <a href="{{ routes.account_url }}" aria-label="Account" class="cart-link">
          <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <button data-cart-open aria-label="Cart" class="cart-link">
          <span class="cart-count-bubble">
            <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span data-cart-count {% if cart.item_count == 0 %}style="display:none"{% endif %}>{{ cart.item_count }}</span>
          </span>
        </button>
      </div>
    </div>
  </div>

  {%- if nav and nav.links.size > 0 -%}
    <div class="nav-bar">
      {%- for link in nav.links -%}
        <div class="nav-item{% if link.links.size == 0 and forloop.last and section.settings.highlight_last %} is-accent{% endif %}">
          <a href="{{ link.url }}">{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <div class="dropdown">
              {%- for child in link.links -%}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</nav>

{%- comment -%} Mobile slide-in nav {%- endcomment -%}
<div class="mobile-nav" id="MobileNav" data-mobile-nav>
  <div class="mobile-nav-panel">
    <button class="mobile-nav-close" data-mobile-nav-close aria-label="Close menu">&times;</button>
    <div style="clear:both"></div>
    {%- if nav -%}
      {%- for link in nav.links -%}
        <a href="{{ link.url }}" class="parent">{{ link.title }}</a>
        {%- for child in link.links -%}
          <a href="{{ child.url }}" class="child">{{ child.title }}</a>
        {%- endfor -%}
      {%- endfor -%}
    {%- endif -%}
    {%- if section.settings.left_link_1_label != blank -%}<a href="{{ section.settings.left_link_1_url }}" class="parent">{{ section.settings.left_link_1_label }}</a>{%- endif -%}
    {%- if section.settings.left_link_2_label != blank -%}<a href="{{ section.settings.left_link_2_url }}" class="parent">{{ section.settings.left_link_2_label }}</a>{%- endif -%}
    {%- if section.settings.right_link_label != blank -%}<a href="{{ section.settings.right_link_url }}" class="parent">{{ section.settings.right_link_label }}</a>{%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "Nazly Habib Design" },
    { "type": "text", "id": "tagline", "label": "Tagline under logo", "default": "Handcrafted Interiors · Cairo & London" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" },
    { "type": "checkbox", "id": "highlight_last", "label": "Highlight last menu item", "default": true },
    { "type": "header", "content": "Top-left links" },
    { "type": "text", "id": "left_link_1_label", "label": "Link 1 label", "default": "About" },
    { "type": "url", "id": "left_link_1_url", "label": "Link 1 URL" },
    { "type": "text", "id": "left_link_2_label", "label": "Link 2 label", "default": "Bespoke Orders" },
    { "type": "url", "id": "left_link_2_url", "label": "Link 2 URL" },
    { "type": "header", "content": "Top-right link" },
    { "type": "text", "id": "right_link_label", "label": "Link label", "default": "Contact" },
    { "type": "url", "id": "right_link_url", "label": "Link URL" }
  ]
}
{% endschema %}
