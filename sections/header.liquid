{%- liquid
  assign menu = section.settings.menu
  assign nav = linklists[menu]
  assign use_shopify_menu = false
  if nav and nav.links.size > 3
    assign use_shopify_menu = true
  endif
  assign brand_name = section.settings.logo_text | default: 'Nazly Habib Design'
  if brand_name == shop.name and shop.name == 'My Store'
    assign brand_name = 'Nazly Habib Design'
  endif
  assign tagline = section.settings.tagline | default: 'Handcrafted Interiors · Cairo & London'
-%}

<nav class="nav">
  <div class="nav-top">
    <div class="nav-left">
      {%- if section.settings.left_link_1_label != blank -%}<a href="{{ section.settings.left_link_1_url }}">{{ section.settings.left_link_1_label }}</a>{%- endif -%}
      {%- if section.settings.left_link_2_label != blank -%}<a href="{{ section.settings.left_link_2_url }}">{{ section.settings.left_link_2_label }}</a>{%- endif -%}
    </div>

    <a href="{{ routes.root_url }}" class="nav-logo">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 320 | image_tag: class: 'logo-img', alt: brand_name, widths: '160,320' }}
      {%- else -%}
        <span class="name">{{ brand_name }}</span>
      {%- endif -%}
      <span class="sub">{{ tagline }}</span>
    </a>

    <div class="nav-right">
      {%- if section.settings.right_link_label != blank -%}<a href="{{ section.settings.right_link_url }}">{{ section.settings.right_link_label }}</a>{%- endif -%}
      <div class="nav-icons">
        <a href="{{ routes.search_url }}" aria-label="Search"><svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></a>
        <a href="/cart" data-cart-toggle aria-label="Cart"><svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg><span class="cart-count hidden" data-cart-count>{{ cart.item_count }}</span></a>
      </div>
      <button class="mobile-toggle" aria-label="Menu"><svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
    </div>
  </div>

  <div class="nav-bar">
    {%- if use_shopify_menu -%}
      {%- for link in nav.links -%}
        <div class="nav-item">
          <a href="{{ link.url }}"{% if link.links.size == 0 and forloop.last and section.settings.highlight_last %} style="color:var(--bd)"{% endif %}>{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <div class="dropdown">
              {%- for child in link.links -%}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="nav-item"><a href="/collections/seating">Seating</a><div class="dropdown"><a href="#">Hamptons Armchair</a><a href="#">Riviera Rattan</a><a href="#">Amalfi Grande Sofa</a><a href="#">Miniature Chair</a><a href="#">View All Seating</a></div></div>
      <div class="nav-item"><a href="/collections/tables">Tables</a><div class="dropdown"><a href="#">Coffee Tables</a><a href="#">Moroccan Side Table</a><a href="#">Painted Side Tables</a><a href="#">The Sloan</a><a href="#">View All Tables</a></div></div>
      <div class="nav-item"><a href="/collections/consoles">Consoles</a><div class="dropdown"><a href="#">Hortensia Console</a><a href="#">Boltons Console</a><a href="#">Burl Wood Console</a><a href="#">Marrakech Console</a><a href="#">Upholstered Console</a><a href="#">View All Consoles</a></div></div>
      <div class="nav-item"><a href="/collections/stools">Stools</a><div class="dropdown"><a href="#">X Stools — All Fabrics</a><a href="#">Butler's Stands</a><a href="#">Bobbin Bar Stools</a><a href="#">View All Stools</a></div></div>
      <div class="nav-item"><a href="/collections/beds">Beds</a><div class="dropdown"><a href="#">Regency Headboard</a><a href="#">Bed Frames (Pre-order)</a></div></div>
      <div class="nav-item"><a href="/collections/accessories">Accessories</a><div class="dropdown"><a href="#">Swoon Trays</a><a href="#">Butler's Tray Stands</a><a href="#">Bahamas Lantern</a><a href="#">Arabesque Mirror</a><a href="#">Bar Cart</a><a href="#">View All</a></div></div>
      <div class="nav-item"><a href="/collections/new-in" style="color:var(--bd)">New In</a></div>
    {%- endif -%}
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "Nazly Habib Design" },
    { "type": "text", "id": "tagline", "label": "Tagline under logo", "default": "Handcrafted Interiors · Cairo & London" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu", "info": "Only used if the menu has 4+ items. Otherwise the built-in NHD nav shows." },
    { "type": "checkbox", "id": "highlight_last", "label": "Highlight last menu item", "default": true },
    { "type": "header", "content": "Top-left links" },
    { "type": "text", "id": "left_link_1_label", "label": "Link 1 label", "default": "About" },
    { "type": "url", "id": "left_link_1_url", "label": "Link 1 URL" },
    { "type": "text", "id": "left_link_2_label", "label": "Link 2 label", "default": "Bespoke Orders" },
    { "type": "url", "id": "left_link_2_url", "label": "Link 2 URL" },
    { "type": "header", "content": "Top-right link" },
    { "type": "text", "id": "right_link_label", "label": "Link label", "default": "Contact" },
    { "type": "url", "id": "right_link_url", "label": "Link URL" }
  ]
}
{% endschema %}
