<div class="page-content"{% if section.settings.content_width == 'narrow' %} style="max-width:600px;margin:0 auto"{% elsif section.settings.content_width == 'medium' %} style="max-width:800px;margin:0 auto"{% endif %}>
  {%- if section.settings.show_title -%}
    <h1>{{ page.title }}</h1>
  {%- endif -%}
  <div class="rte">{{ page.content }}</div>
</div>

{% schema %}
{
  "name": "Page",
  "settings": [
    { "type": "checkbox", "id": "show_title", "label": "Show page title", "default": true },
    { "type": "select", "id": "content_width", "label": "Content width", "options": [
      { "value": "narrow", "label": "Narrow (600px)" },
      { "value": "medium", "label": "Medium (800px)" },
      { "value": "wide", "label": "Wide (full)" }
    ], "default": "medium" }
  ]
}
{% endschema %}
