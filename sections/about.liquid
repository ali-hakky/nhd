{%- comment -%} About / founder story {%- endcomment -%}
<section class="about">
  <div class="about-img">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 800 | image_tag: alt: section.settings.heading | escape, loading: 'lazy', widths: '400,600,800' }}
    {%- else -%}
      <img src="{{ 'about-nazly.jpg' | asset_url }}" alt="{{ section.settings.heading | escape }}" loading="lazy">
    {%- endif -%}
    {%- if section.settings.badge_text != blank -%}
      <div class="about-badge"><span>{{ section.settings.badge_text }}</span></div>
    {%- endif -%}
  </div>
  <div>
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 class="about-title">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %}<br><em>{{ section.settings.heading_accent }}</em>{% endif %}</h2>
    <div class="about-body">{{ section.settings.body }}</div>
    {%- if section.settings.signature != blank -%}<p class="about-sig">{{ section.settings.signature }}</p>{%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "About",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Portrait image" },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Est. 2010" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Meet Nazly" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Design with" },
    { "type": "text", "id": "heading_accent", "label": "Heading (italic accent)", "default": "soul & intention" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>I'm Nazly — wife, mother of three, and someone who has spent most of her life quietly obsessed with beautiful rooms.</p><p>What started as a genuine love of chinoiserie, antiques and the kind of interiors you want to live inside rather than just admire, eventually became something more.</p><p>Today, Nazly Habib Design is a small studio making handcrafted rattan, wicker and upholstered furniture — bespoke pieces built around your home, your taste and your life. Every piece is made to order, which means it was made for you.</p>" },
    { "type": "text", "id": "signature", "label": "Signature", "default": "— Nazly Habib" }
  ],
  "presets": [{ "name": "About" }]
}
{% endschema %}
