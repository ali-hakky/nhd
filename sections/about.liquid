<section class="about">
  <div class="about-img">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'About Nazly' }}
    {%- else -%}
      <div class="ph" style="width:100%;height:100%">Photo of Nazly / Showroom</div>
    {%- endif -%}
    {%- if section.settings.badge_text != blank -%}
      <div class="about-badge"><span>{{ section.settings.badge_text }}</span></div>
    {%- endif -%}
  </div>
  <div>
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 class="about-title">{{ section.settings.title }}{% if section.settings.title_accent != blank %}<br><em>{{ section.settings.title_accent }}</em>{% endif %}</h2>
    {%- if section.settings.body != blank -%}<div class="about-body">{{ section.settings.body }}</div>{%- endif -%}
    {%- if section.settings.signature != blank -%}<p class="about-sig">{{ section.settings.signature }}</p>{%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "About",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge_text", "label": "Badge text (circle)", "default": "Est.<br>2010" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Meet Nazly" },
    { "type": "text", "id": "title", "label": "Title", "default": "Design with" },
    { "type": "text", "id": "title_accent", "label": "Title italic", "default": "soul & intention" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>I'm Nazly — wife, mother of three, and someone who has spent most of her life quietly obsessed with beautiful rooms.</p><p>What started as a genuine love of chinoiserie, antiques and the kind of interiors you want to live inside rather than just admire, eventually became something more.</p><p>Today, Nazly Habib Design is a small studio making handcrafted rattan, wicker and upholstered furniture — bespoke pieces built around your home, your taste and your life.</p>" },
    { "type": "text", "id": "signature", "label": "Signature", "default": "— Nazly Habib" }
  ],
  "presets": [{ "name": "About" }]
}
{% endschema %}
