<div class="blog-page">
  <h1>{{ blog.title }}</h1>
  <div class="blog-grid">
    {%- paginate blog.articles by 9 -%}
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="blog-card">
          <div class="blog-card-img">
            {%- if article.image -%}
              {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="blog-card-body">
            <div class="blog-card-date">{{ article.published_at | date: '%B %d, %Y' }}</div>
            <h2 class="blog-card-title">{{ article.title }}</h2>
            <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
          </div>
        </a>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <div class="pagination" style="grid-column:1/-1">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">←</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span class="current">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">→</a>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog page",
  "settings": []
}
{% endschema %}
