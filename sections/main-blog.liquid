<div class="blog-page">
  <h1>{{ blog.title }}</h1>
  <div class="blog-grid">
    {%- paginate blog.articles by section.settings.articles_per_page -%}
      {%- for article in blog.articles -%}
        <a href="{{ article.url }}" class="blog-card">
          <div class="blog-card-img">
            {%- if article.image -%}
              {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="blog-card-body">
            {%- if section.settings.show_date -%}
              <div class="blog-card-date">{{ article.published_at | date: '%B %d, %Y' }}</div>
            {%- endif -%}
            <h2 class="blog-card-title">{{ article.title }}</h2>
            {%- if section.settings.show_excerpt -%}
              <p class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <div class="pagination" style="grid-column:1/-1">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">←</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>{%- else -%}<span class="current">{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}">→</a>{%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog page",
  "settings": [
    { "type": "checkbox", "id": "show_date", "label": "Show article date", "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show article excerpt", "default": true },
    { "type": "range", "id": "articles_per_page", "label": "Articles per page", "min": 3, "max": 18, "step": 3, "default": 9 },
    { "type": "select", "id": "columns", "label": "Grid columns", "options": [
      { "value": "2", "label": "2 columns" },
      { "value": "3", "label": "3 columns" }
    ], "default": "3" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [
      { "value": "landscape", "label": "Landscape (16:9)" },
      { "value": "square", "label": "Square (1:1)" },
      { "value": "portrait", "label": "Portrait (3:4)" }
    ], "default": "landscape" }
  ]
}
{% endschema %}
