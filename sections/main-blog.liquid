<div class="blog-page">
  <h1>{{ blog.title }}</h1>

  {%- paginate blog.articles by 12 -%}
    {%- if blog.articles.size > 0 -%}
      <div class="blog-grid">
        {%- for article in blog.articles -%}
          <a href="{{ article.url }}" class="blog-card">
            <div class="blog-card-img">
              {%- if article.image -%}
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="blog-card-body">
              <div class="blog-card-date">{{ article.published_at | date: '%B %d, %Y' }}</div>
              <div class="blog-card-title">{{ article.title }}</div>
              <div class="blog-card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 150 }}</div>
            </div>
          </a>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">&laquo;</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span class="current">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}">&raquo;</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <p style="text-align:center;padding:60px 0;color:var(--mu);font-size:13px">No articles yet.</p>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{
  "name": "Blog posts",
  "tag": "section",
  "settings": []
}
{% endschema %}
