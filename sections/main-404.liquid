<div class="page-404">
  {%- if section.settings.image -%}
    <div style="margin-bottom:24px">
      {{ section.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: section.settings.heading }}
    </div>
  {%- endif -%}
  <h1>404</h1>
  <h2>{{ section.settings.heading | default: 'Page not found' }}</h2>
  <p>{{ section.settings.text | default: 'The page you were looking for does not exist.' }}</p>
  <a href="{{ section.settings.button_url | default: '/' }}" class="btn">{{ section.settings.button_label | default: 'Back to home' }}</a>
</div>

{% schema %}
{
  "name": "404 page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page not found" },
    { "type": "textarea", "id": "text", "label": "Body text", "default": "The page you were looking for does not exist." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Back to home" },
    { "type": "url", "id": "button_url", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Background image" }
  ]
}
{% endschema %}
