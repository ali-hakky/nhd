<div class="blog-page">
  <h1>Collections</h1>

  <div class="grid-4">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="prod-card">
        <div class="prod-img med">
          {%- if collection.image -%}
            {{ collection.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title, sizes: '(max-width:640px) 50vw, 25vw', widths: '300,450,600' }}
          {%- elsif collection.products.first and collection.products.first.featured_image -%}
            {{ collection.products.first.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection.title, sizes: '(max-width:640px) 50vw, 25vw', widths: '300,450,600' }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="prod-body">
          <div class="prod-name">{{ collection.title }}</div>
          <div class="prod-mat">{{ collection.products_count }} products</div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "settings": []
}
{% endschema %}
