<section class="newsletter">
  {%- if section.settings.eyebrow != blank -%}<span class="eyebrow" style="color:rgba(255,255,255,.6)">{{ section.settings.eyebrow }}</span>{%- endif -%}
  <h2 class="nl-title">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent }}</em>{% endif %}</h2>
  {%- if section.settings.subtext != blank -%}<p class="nl-sub">{{ section.settings.subtext }}</p>{%- endif -%}
  {%- form 'customer', id: 'newsletter' -%}
    {%- if form.posted_successfully? -%}
      <p style="color:#fff;margin-bottom:16px">{{ 'general.newsletter.success' | t }}</p>
    {%- endif -%}
    {%- if form.errors -%}
      <p style="color:#ffcccc;margin-bottom:16px">{{ form.errors | default_errors }}</p>
    {%- endif -%}
    <div class="nl-form">
      <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" required aria-label="{{ 'general.newsletter.placeholder' | t }}">
      <input type="hidden" name="contact[tags]" value="newsletter">
      <button type="submit">{{ 'general.newsletter.submit' | t }}</button>
    </div>
  {%- endform -%}
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the loop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New pieces," },
    { "type": "text", "id": "heading_accent", "label": "Heading italic", "default": "first." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Early access to arrivals, behind-the-scenes & design inspiration from Nazly." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
