<div class="search-page">
  <h1>Search</h1>

  <form action="/search" method="get" class="search-form">
    <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Search our store...">
    <button type="submit">Search</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p style="text-align:center;color:var(--mu);font-size:12px;margin-bottom:24px">
        {{ search.results_count }} {{ search.results_count | pluralize: 'result', 'results' }} for &ldquo;{{ search.terms }}&rdquo;
      </p>
      <div class="grid-4">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'product-card', product: item, image_height: 'med', show_price: true -%}
          {%- else -%}
            <a href="{{ item.url }}" class="prod-card">
              <div class="prod-body">
                <div class="prod-name">{{ item.title }}</div>
                <div class="prod-mat">{{ item.content | strip_html | truncate: 120 }}</div>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center;color:var(--mu);font-size:13px;padding:40px 0">
        No results found for &ldquo;{{ search.terms }}&rdquo;. Please try a different search.
      </p>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search results",
  "tag": "section",
  "settings": []
}
{% endschema %}
