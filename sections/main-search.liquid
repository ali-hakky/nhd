<div class="search-page">
  <h1>{{ 'general.search.title' | t }}</h1>
  <div class="search-form">
    <form action="/search" method="get">
      <div class="search-form" style="margin-bottom:0">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search.placeholder' | t }}">
        <button type="submit">{{ 'general.search.submit' | t }}</button>
      </div>
    </form>
  </div>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <div class="grid-3">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {%- render 'product-card', product: item, image_height: 'med', show_price: true -%}
          {%- else -%}
            <a href="{{ item.url }}" class="prod-card">
              <div class="prod-body">
                <div class="prod-name">{{ item.title }}</div>
                <div class="prod-mat">{{ item.content | strip_html | truncate: 120 }}</div>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center;color:var(--mu);padding:40px 0">{{ 'general.search.no_results' | t }} "{{ search.terms }}"</p>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Search page",
  "settings": []
}
{% endschema %}
