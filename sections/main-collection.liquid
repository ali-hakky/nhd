<div class="collection-hero">
  <h1>{{ collection.title }}</h1>
  {%- if section.settings.show_description and collection.description != blank -%}<p>{{ collection.description }}</p>{%- endif -%}
</div>

{%- if section.settings.show_sort or section.settings.show_count -%}
  <div class="collection-bar">
    {%- if section.settings.show_count -%}
      <span>{{ collection.products_count }} {{ 'collection.products_count' | t: count: collection.products_count }}</span>
    {%- endif -%}
    {%- if section.settings.show_sort -%}
      <label for="sort-by" class="hidden">{{ 'collection.sort_by' | t }}</label>
      <select id="sort-by" onchange="window.location.href=this.value" aria-label="{{ 'collection.sort_by' | t }}">
        {%- for option in collection.sort_options -%}
          <option value="{{ option.url }}"{% if option.value == collection.sort_by %} selected{% endif %}>{{ option.name }}</option>
        {%- endfor -%}
      </select>
    {%- endif -%}
  </div>
{%- endif -%}

<div class="collection-grid">
  <div class="grid-{{ section.settings.columns | default: '3' }}">
    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- for product in collection.products -%}
        {%- render 'product-card', product: product, image_height: section.settings.image_ratio, show_price: true -%}
      {%- else -%}
        <p style="grid-column:1/-1;text-align:center;padding:40px;color:var(--mu)">No products in this collection yet.</p>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" style="grid-column:1/-1" aria-label="Pagination">
          {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">←</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" aria-label="Page {{ part.title }}">{{ part.title }}</a>
            {%- else -%}
              <span class="current" aria-current="page">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">→</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "checkbox", "id": "show_sort", "label": "Show sort dropdown", "default": true },
    { "type": "checkbox", "id": "show_count", "label": "Show product count", "default": true },
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 6, "max": 24, "step": 3, "default": 12 },
    { "type": "select", "id": "columns", "label": "Grid columns", "options": [
      { "value": "2", "label": "2 columns" },
      { "value": "3", "label": "3 columns" },
      { "value": "4", "label": "4 columns" }
    ], "default": "3" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [
      { "value": "tall", "label": "Tall (3:4)" },
      { "value": "square", "label": "Square (1:1)" },
      { "value": "wide", "label": "Wide (4:3)" }
    ], "default": "tall" }
  ]
}
{% endschema %}
