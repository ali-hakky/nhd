<div class="cart-overlay"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-head">
    <h3>Your Cart (<span data-cart-count>{{ cart.item_count }}</span>)</h3>
    <button class="cart-close" aria-label="Close cart">&times;</button>
  </div>

  <div class="cart-body">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="cart-item">
          <div class="cart-item-img">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title }}" loading="lazy">
            {%- endif -%}
          </div>
          <div class="cart-item-info">
            <div class="cart-item-title">{{ item.product.title }}</div>
            {%- unless item.variant.title == 'Default Title' -%}
              <div class="cart-item-variant">{{ item.variant.title }}</div>
            {%- endunless -%}
            <div class="cart-item-price">{{ item.price | money }}</div>
            <div class="cart-qty">
              <button type="button" data-qty-change="-1" data-key="{{ item.key }}">-</button>
              <input type="text" value="{{ item.quantity }}" readonly>
              <button type="button" data-qty-change="1" data-key="{{ item.key }}">+</button>
            </div>
            <button class="cart-item-remove" data-remove-key="{{ item.key }}">Remove</button>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="cart-empty">Your cart is empty.</div>
    {%- endif -%}
  </div>

  <div class="cart-foot{% if cart.item_count == 0 %} hidden{% endif %}">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span>{{ cart.total_price | money }}</span>
    </div>
    <a href="/checkout" class="btn cart-checkout">Checkout</a>
    <p class="cart-note">Shipping and taxes calculated at checkout</p>
  </div>
</div>

{% schema %}
{
  "name": "Cart drawer",
  "tag": "div",
  "settings": []
}
{% endschema %}
