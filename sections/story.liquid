<section class="story">
  <div class="story-img">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.title }}
    {%- else -%}
      <div class="ph" style="width:100%;height:100%;min-height:500px">Story / Studio Photo</div>
    {%- endif -%}
  </div>
  <div class="story-panel">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 class="story-title">{{ section.settings.title }}{% if section.settings.title_accent != blank %} <em>{{ section.settings.title_accent }}</em>{% endif %}</h2>
    {%- if section.blocks.size > 0 -%}
      <div class="story-tags">
        {%- for block in section.blocks -%}
          <span class="s-tag" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.body != blank -%}<p class="story-body">{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.settings.link_label != blank -%}
      <a href="{{ section.settings.link_url | default: '#' }}" class="story-link">{{ section.settings.link_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Story panel",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our philosophy" },
    { "type": "text", "id": "title", "label": "Title", "default": "Design should make you feel" },
    { "type": "text", "id": "title_accent", "label": "Title italic", "default": "something." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Every piece begins with a conversation. We source the finest rattan and the most characterful fabrics from houses like Schumacher, Brunschwig & Fils, GP & J Baker and Zoffany — and we never settle for ordinary.</p>" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Meet Nazly →" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    {
      "type": "tag",
      "name": "Tag",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Handmade" }
      ]
    }
  ],
  "presets": [{ "name": "Story panel", "blocks": [
    { "type": "tag", "settings": { "label": "100% Handmade" } },
    { "type": "tag", "settings": { "label": "Bespoke" } },
    { "type": "tag", "settings": { "label": "Made to Order" } },
    { "type": "tag", "settings": { "label": "Natural Materials" } }
  ] }]
}
{% endschema %}
