{%- comment -%} Philosophy / story split panel {%- endcomment -%}
<section class="story">
  <div class="story-img">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1000 | image_tag: alt: section.settings.heading, loading: 'lazy', widths: '500,750,1000' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
  <div class="story-panel">
    {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
    <h2 class="story-title">{{ section.settings.heading }}{% if section.settings.heading_accent != blank %} <em>{{ section.settings.heading_accent }}</em>{% endif %}</h2>
    {%- if section.blocks.size > 0 -%}
      <div class="story-tags">
        {%- for block in section.blocks -%}
          <span class="s-tag" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- if section.settings.body != blank -%}<p class="story-body">{{ section.settings.body }}</p>{%- endif -%}
    {%- if section.settings.link_label != blank -%}<a href="{{ section.settings.link_url | default: '#' }}" class="story-link">{{ section.settings.link_label }}</a>{%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Story panel",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our philosophy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Design should make you feel" },
    { "type": "text", "id": "heading_accent", "label": "Heading (italic accent)", "default": "something." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "Every piece begins with a conversation. We source the finest rattan and the most characterful fabrics from houses like Schumacher, Brunschwig & Fils, GP & J Baker and Zoffany — and we never settle for ordinary. Your home should feel like an extension of who you are." },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Meet Nazly →" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "blocks": [
    { "type": "tag", "name": "Tag", "settings": [ { "type": "text", "id": "label", "label": "Tag", "default": "Handmade" } ] }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Story panel",
      "blocks": [
        { "type": "tag", "settings": { "label": "100% Handmade" } },
        { "type": "tag", "settings": { "label": "Bespoke" } },
        { "type": "tag", "settings": { "label": "Made to Order" } },
        { "type": "tag", "settings": { "label": "Natural Materials" } }
      ]
    }
  ]
}
{% endschema %}
