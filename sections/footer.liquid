<footer class="footer">
  <div class="footer-grid">
    <div>
      <div class="f-brand">{{ shop.name }}</div>
      <p class="f-desc">{{ section.settings.description | default: 'Handcrafted rattan, wicker & upholstered furniture made to order.' }}</p>
      <div class="f-social">
        {%- if section.settings.instagram != blank -%}<a href="{{ section.settings.instagram }}" target="_blank">Instagram</a>{%- endif -%}
        {%- if section.settings.pinterest != blank -%}<a href="{{ section.settings.pinterest }}" target="_blank">Pinterest</a>{%- endif -%}
      </div>
    </div>
    {%- for block in section.blocks -%}
      {%- if block.type == 'menu' -%}
        <div {{ block.shopify_attributes }}>
          <div class="f-head">{{ block.settings.title }}</div>
          <ul class="f-links">
            {%- for link in linklists[block.settings.menu].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <div class="footer-btm">
    <p class="f-copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    <div class="f-pay">
      {%- for type in shop.enabled_payment_types -%}
        <span>{{ type | capitalize }}</span>
      {%- endfor -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "description", "label": "Brand description", "default": "Handcrafted rattan, wicker & upholstered furniture made to order. Every piece made with personality, for homes that have it too. Cairo & London." },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Column title", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ]
}
{% endschema %}
