<div class="contact-page">
  <div>
    <h1>{{ page.title | default: 'Contact Us' }}</h1>
    {%- if page.content != blank -%}
      <div class="contact-intro rte">{{ page.content }}</div>
    {%- endif -%}
  </div>

  <div>
    {%- form 'contact', class: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <p style="color:var(--bd);margin-bottom:16px;font-size:13px">Thank you for your message. We will get back to you soon.</p>
      {%- endif -%}

      {%- if form.errors -%}
        <p style="color:#c0392b;margin-bottom:16px;font-size:13px">{{ form.errors | default_errors }}</p>
      {%- endif -%}

      <label for="contact-name">Name</label>
      <input type="text" id="contact-name" name="contact[name]" required>

      <label for="contact-email">Email</label>
      <input type="email" id="contact-email" name="contact[email]" required>

      <label for="contact-phone">Phone</label>
      <input type="tel" id="contact-phone" name="contact[phone]">

      <label for="contact-subject">Subject</label>
      <input type="text" id="contact-subject" name="contact[subject]" value="{% if request.params.product %}Enquiry about {{ request.params.product }}{% endif %}">

      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="contact[body]" required>{% if request.params.product %}I would like to enquire about {{ request.params.product }}.{% endif %}</textarea>

      <button type="submit" class="btn">Send Message</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "settings": []
}
{% endschema %}
