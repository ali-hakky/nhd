<div class="contact-page">
  <div>
    <h1>{{ section.settings.heading | default: 'Get in Touch' }}</h1>
    {%- if section.settings.intro != blank -%}<p class="contact-intro">{{ section.settings.intro }}</p>{%- endif -%}
    {%- if section.settings.email != blank or section.settings.phone != blank or section.settings.address != blank -%}
      <div class="contact-details">
        {%- if section.settings.email != blank -%}<div>✉ <a href="mailto:{{ section.settings.email }}" style="color:var(--mu);text-decoration:none">{{ section.settings.email }}</a></div>{%- endif -%}
        {%- if section.settings.phone != blank -%}<div>☎ <a href="tel:{{ section.settings.phone | remove: ' ' }}" style="color:var(--mu);text-decoration:none">{{ section.settings.phone }}</a></div>{%- endif -%}
        {%- if section.settings.address != blank -%}<div>📍 {{ section.settings.address }}</div>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="rte">{{ page.content }}</div>
  </div>
  <div>
    {%- form 'contact', id: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-success">Thank you! We'll be in touch soon.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <div class="form-errors">
          <p>Please fix the following:</p>
          <ul>
            {%- for field in form.errors -%}
              <li>{{ form.errors.messages[field] }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
      <div class="contact-form">
        <label for="contact-name">{{ 'contact.name' | t }}</label>
        <input type="text" id="contact-name" name="contact[name]" autocomplete="name" required>
        <label for="contact-email">{{ 'contact.email' | t }}</label>
        <input type="email" id="contact-email" name="contact[email]" autocomplete="email" required>
        <label for="contact-phone">{{ 'contact.phone' | t }}</label>
        <input type="tel" id="contact-phone" name="contact[phone]" autocomplete="tel">
        <label for="contact-subject">Subject</label>
        <input type="text" id="contact-subject" name="contact[subject]" value="{{ request.page_type | default: '' }}{% if request.params.product %} — {{ request.params.product }}{% endif %}">
        <label for="contact-message">{{ 'contact.message' | t }}</label>
        <textarea id="contact-message" name="contact[body]" required>{% if request.params.product %}I'd like to enquire about {{ request.params.product }}.{% endif %}</textarea>
        <button type="submit" class="btn">{{ 'contact.submit' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in Touch" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Whether you're looking for a bespoke piece, need help choosing a fabric, or just want to say hello — we'd love to hear from you." },
    { "type": "text", "id": "email", "label": "Email address", "default": "hello@nazlyhabibdesign.com" },
    { "type": "text", "id": "phone", "label": "Phone" },
    { "type": "text", "id": "address", "label": "Address", "default": "Cairo & London" }
  ]
}
{% endschema %}
