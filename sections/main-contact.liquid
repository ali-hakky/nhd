<div class="contact-page">
  <div>
    <h1>{{ section.settings.heading | default: 'Get in Touch' }}</h1>
    {%- if section.settings.intro != blank -%}<p class="contact-intro">{{ section.settings.intro }}</p>{%- endif -%}
    {%- if section.settings.email != blank or section.settings.phone != blank or section.settings.address != blank -%}
      <div class="contact-details">
        {%- if section.settings.email != blank -%}<div>✉ {{ section.settings.email }}</div>{%- endif -%}
        {%- if section.settings.phone != blank -%}<div>☎ {{ section.settings.phone }}</div>{%- endif -%}
        {%- if section.settings.address != blank -%}<div>📍 {{ section.settings.address }}</div>{%- endif -%}
      </div>
    {%- endif -%}
    <div class="rte">{{ page.content }}</div>
  </div>
  <div>
    {%- form 'contact', id: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <p style="color:var(--bd);margin-bottom:16px">Thank you! We'll be in touch soon.</p>
      {%- endif -%}
      <div class="contact-form">
        <label>{{ 'contact.name' | t }}</label>
        <input type="text" name="contact[name]" required>
        <label>{{ 'contact.email' | t }}</label>
        <input type="email" name="contact[email]" required>
        <label>{{ 'contact.phone' | t }}</label>
        <input type="tel" name="contact[phone]">
        <label>Subject</label>
        <input type="text" name="contact[subject]" value="{{ request.page_type | default: '' }}{% if request.params.product %} — {{ request.params.product }}{% endif %}">
        <label>{{ 'contact.message' | t }}</label>
        <textarea name="contact[body]" required>{% if request.params.product %}I'd like to enquire about {{ request.params.product }}.{% endif %}</textarea>
        <button type="submit" class="btn">{{ 'contact.submit' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in Touch" },
    { "type": "textarea", "id": "intro", "label": "Intro text", "default": "Whether you're looking for a bespoke piece, need help choosing a fabric, or just want to say hello — we'd love to hear from you." },
    { "type": "text", "id": "email", "label": "Email address", "default": "hello@nazlyhabibdesign.com" },
    { "type": "text", "id": "phone", "label": "Phone" },
    { "type": "text", "id": "address", "label": "Address", "default": "Cairo & London" }
  ]
}
{% endschema %}
