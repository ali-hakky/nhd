{%- comment -%} Open Graph & Twitter social meta tags {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:title" content="{{ page_title | default: shop.name }}">
<meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">
<meta property="og:description" content="{{ page_description | default: shop.description | default: shop.name | escape }}">
{%- assign share_img = page_image | default: settings.share_image -%}
{%- if share_img -%}
  <meta property="og:image" content="http:{{ share_img | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ share_img | image_url: width: 1200 }}">
  <meta name="twitter:image" content="https:{{ share_img | image_url: width: 1200 }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ page_title | default: shop.name }}">
<meta name="twitter:description" content="{{ page_description | default: shop.description | default: shop.name | escape }}">
