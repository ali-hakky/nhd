<div class="center-page" style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center">
  {%- if shop.logo != blank -%}
    <img src="{{ shop.logo | image_url: width: 320 }}" alt="{{ shop.name }}" style="max-width:220px;margin:0 auto 20px">
  {%- endif -%}
  <span class="eyebrow">Coming soon</span>
  <h1 style="font-size:48px">{{ shop.name }}</h1>
  <p class="hero-sub" style="color:var(--mu);max-width:440px;margin:0 auto 28px">Handcrafted rattan, wicker &amp; upholstered furniture. Our online studio is opening soon.</p>

  {%- form 'storefront_password', class: 'nl-form', style: 'background:transparent' -%}
    {%- if form.errors -%}<p class="form-status error" style="width:100%">{{ form.errors | default_errors }}</p>{%- endif -%}
    <input type="password" name="password" placeholder="Enter store password" aria-label="Password" style="border-color:var(--br);background:#fff;color:var(--ink)">
    <button type="submit" style="background:var(--bd);color:#fff">Enter</button>
  {%- endform -%}

  <p style="margin-top:24px">
    <a href="https://instagram.com/nazlyhabibdesigns" class="story-link" target="_blank" rel="noopener">@nazlyhabibdesigns →</a>
  </p>
</div>
