<div class="page-wrap account-wrap">
  <h1 class="product-title" style="text-align:center;margin-bottom:8px">Activate Account</h1>
  <p class="prod-lead" style="text-align:center;margin-bottom:24px">Create your password to activate your account.</p>
  {%- form 'activate_customer_password' -%}
    {%- if form.errors -%}<p class="form-status error">{{ form.errors | default_errors }}</p>{%- endif -%}
    <div class="field"><label for="Pw">Password</label><input type="password" id="Pw" name="customer[password]" required></div>
    <div class="field"><label for="PwC">Confirm password</label><input type="password" id="PwC" name="customer[password_confirmation]" required></div>
    <button type="submit" class="btn" style="width:100%">Activate account</button>
    <button type="submit" name="decline" class="cart-continue" style="margin-top:10px">Decline invitation</button>
  {%- endform -%}
</div>
