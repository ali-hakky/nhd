<div class="page-content" style="max-width:400px">
  <h1>Activate Account</h1>
  {%- form 'activate_customer_password' -%}
    {%- if form.errors -%}
      <div class="form-errors" style="margin-bottom:16px">
        <p>{{ form.errors | default_errors }}</p>
      </div>
    {%- endif -%}
    <div class="contact-form">
      <label for="activate-pass">Password</label>
      <input type="password" id="activate-pass" name="customer[password]" autocomplete="new-password" required>
      <label for="activate-pass-confirm">Confirm password</label>
      <input type="password" id="activate-pass-confirm" name="customer[password_confirmation]" autocomplete="new-password" required>
      <button type="submit" class="btn" style="margin-top:16px">Activate</button>
    </div>
  {%- endform -%}
</div>
