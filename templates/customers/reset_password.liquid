<div class="page-content" style="max-width:400px">
  <h1>Reset Password</h1>
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}
      <div class="form-errors" style="margin-bottom:16px">
        <p>{{ form.errors | default_errors }}</p>
      </div>
    {%- endif -%}
    <div class="contact-form">
      <label for="reset-pass">New password</label>
      <input type="password" id="reset-pass" name="customer[password]" autocomplete="new-password" required>
      <label for="reset-pass-confirm">Confirm password</label>
      <input type="password" id="reset-pass-confirm" name="customer[password_confirmation]" autocomplete="new-password" required>
      <button type="submit" class="btn" style="margin-top:16px">Reset</button>
    </div>
  {%- endform -%}
</div>
