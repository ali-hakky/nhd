<div class="page-wrap account-wrap">
  <h1 class="product-title" style="text-align:center;margin-bottom:24px">Reset Password</h1>
  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}<p class="form-status error">{{ form.errors | default_errors }}</p>{%- endif -%}
    <div class="field"><label for="Pw">New password</label><input type="password" id="Pw" name="customer[password]" required></div>
    <div class="field"><label for="PwC">Confirm password</label><input type="password" id="PwC" name="customer[password_confirmation]" required></div>
    <button type="submit" class="btn" style="width:100%">Reset password</button>
  {%- endform -%}
</div>
