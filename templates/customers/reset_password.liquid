<div class="page-content" style="max-width:400px">
  <h1>Reset Password</h1>
  {%- form 'reset_customer_password' -%}
    <div class="contact-form">
      <label>New password</label>
      <input type="password" name="customer[password]" required>
      <label>Confirm password</label>
      <input type="password" name="customer[password_confirmation]" required>
      <button type="submit" class="btn" style="margin-top:16px">Reset</button>
    </div>
  {%- endform -%}
</div>
