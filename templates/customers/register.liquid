<div class="page-wrap account-wrap">
  <h1 class="product-title" style="text-align:center;margin-bottom:24px">Create Account</h1>
  {%- form 'create_customer' -%}
    {%- if form.errors -%}<p class="form-status error">{{ form.errors | default_errors }}</p>{%- endif -%}
    <div class="field"><label for="FirstName">First name</label><input type="text" id="FirstName" name="customer[first_name]"></div>
    <div class="field"><label for="LastName">Last name</label><input type="text" id="LastName" name="customer[last_name]"></div>
    <div class="field"><label for="Email">Email</label><input type="email" id="Email" name="customer[email]" required></div>
    <div class="field"><label for="Password">Password</label><input type="password" id="Password" name="customer[password]" required></div>
    <button type="submit" class="btn" style="width:100%">Create account</button>
  {%- endform -%}
  <p style="text-align:center;margin-top:24px">Already have an account? <a href="{{ routes.account_login_url }}" class="story-link">Sign in →</a></p>
</div>
