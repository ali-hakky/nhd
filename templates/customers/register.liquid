<div class="page-content" style="max-width:400px">
  <h1>Create Account</h1>
  {%- form 'create_customer' -%}
    {%- if form.errors -%}
      <div class="form-errors" style="margin-bottom:16px">
        <p>{{ form.errors | default_errors }}</p>
      </div>
    {%- endif -%}
    <div class="contact-form">
      <label for="reg-first">First name</label>
      <input type="text" id="reg-first" name="customer[first_name]" autocomplete="given-name">
      <label for="reg-last">Last name</label>
      <input type="text" id="reg-last" name="customer[last_name]" autocomplete="family-name">
      <label for="reg-email">Email</label>
      <input type="email" id="reg-email" name="customer[email]" autocomplete="email" required>
      <label for="reg-pass">Password</label>
      <input type="password" id="reg-pass" name="customer[password]" autocomplete="new-password" required>
      <button type="submit" class="btn" style="margin-top:16px">Create</button>
    </div>
    <p style="margin-top:16px;font-size:12px">Already have an account? <a href="{{ routes.account_login_url }}" style="color:var(--bd)">Sign in</a></p>
  {%- endform -%}
</div>
