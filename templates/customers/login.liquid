<div class="page-content" style="max-width:400px">
  <h1>Login</h1>
  {%- form 'customer_login' -%}
    <div class="contact-form">
      <label>Email</label>
      <input type="email" name="customer[email]" required>
      <label>Password</label>
      <input type="password" name="customer[password]" required>
      <button type="submit" class="btn" style="margin-top:16px">Sign In</button>
    </div>
    <p style="margin-top:16px;font-size:12px"><a href="{{ routes.account_recover_url }}" style="color:var(--bd)">Forgot password?</a> · <a href="{{ routes.account_register_url }}" style="color:var(--bd)">Create account</a></p>
  {%- endform -%}
</div>
