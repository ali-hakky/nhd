<div class="page-content" style="max-width:400px">
  <h1>Login</h1>
  {%- form 'customer_login' -%}
    {%- if form.errors -%}
      <div class="form-errors" style="margin-bottom:16px">
        <p>{{ form.errors | default_errors }}</p>
      </div>
    {%- endif -%}
    <div class="contact-form">
      <label for="login-email">Email</label>
      <input type="email" id="login-email" name="customer[email]" autocomplete="email" required>
      <label for="login-pass">Password</label>
      <input type="password" id="login-pass" name="customer[password]" autocomplete="current-password" required>
      <button type="submit" class="btn" style="margin-top:16px">Sign In</button>
    </div>
    <p style="margin-top:16px;font-size:12px"><a href="{{ routes.account_recover_url }}" style="color:var(--bd)">Forgot password?</a> · <a href="{{ routes.account_register_url }}" style="color:var(--bd)">Create account</a></p>
  {%- endform -%}

  <div id="recover" style="display:none;margin-top:32px;padding-top:24px;border-top:1px solid var(--br)">
    <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:300;margin-bottom:12px">Reset Password</h2>
    {%- form 'recover_customer_password' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-success">We've sent you an email with a link to reset your password.</p>
      {%- endif -%}
      <div class="contact-form">
        <label for="recover-email">Email</label>
        <input type="email" id="recover-email" name="email" autocomplete="email" required>
        <button type="submit" class="btn" style="margin-top:16px">Reset Password</button>
      </div>
    {%- endform -%}
  </div>
</div>
<script>
  if(window.location.hash==='#recover'||document.querySelector('[data-recover]')){
    document.getElementById('recover').style.display='block';
  }
  document.querySelectorAll('a[href*="recover"]').forEach(function(a){
    a.addEventListener('click',function(e){
      e.preventDefault();
      document.getElementById('recover').style.display='block';
      document.getElementById('recover').scrollIntoView({behavior:'smooth'});
    });
  });
</script>
